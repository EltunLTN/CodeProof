{
  "name": "codeproof-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vinext dev",
    "build": "vinext build",
    "start": "vinext start",
    "test": "npm run test:unit && npm run test:python && npm run build",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test:python": "python -m unittest discover -s tests -p test_ml.py -v",
    "train:model": "python -m ml.train_model",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@uiw/react-codemirror": "^4.25.11",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.5",
    "wrangler": "^4.111.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "type": "module"
}
